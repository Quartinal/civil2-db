{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ESNext", "DOM"],
        "types": ["bun-types"],
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationDir": "./dist/types",
        "rootDir": "./src"
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "scripts"]
}
